---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Case Studies — GTM Systems That Drove Real Outcomes";
const pageDescription = "Six in-depth case studies covering developer-led growth, propensity scoring, lifecycle orchestration, privacy pivots, marketplace growth, and clean room architecture. Real systems, real results.";

const caseStudies = [
  {
    number: "01",
    title: "Developer-to-Enterprise Pipeline for Open Source AI",
    description: "How we turned GitHub stars into six-figure deals by building visibility into the developer evaluation process. Multi-layer signal capture from GitHub, Hugging Face, and API usage fed a dual-track scoring system that separated technical validation from commercial readiness.",
    keyMetric: "$18.3M+",
    metricLabel: "Partner Pipeline",
    image: "/case-studies/hero-image-01.png",
    concepts: ["Developer-led growth", "PLG motion", "Dual-track scoring", "Champion enablement"],
    url: "/case-studies/developer-discovery"
  },
  {
    number: "02",
    title: "Propensity Scoring That Actually Works",
    description: "The propensity model was mathematically sound. It was also practically useless. The prediction problem turned out to be a data governance problem — four systems with different naming conventions, conflicting data types, and no automated sync. We rebuilt it from the ground up.",
    keyMetric: "30%",
    metricLabel: "Prediction Accuracy Improvement",
    image: "/case-studies/hero-image-02.png",
    concepts: ["Data governance", "CRM integration", "Propensity modeling", "Vertical segmentation"],
    url: "/case-studies/propensity-scoring"
  },
  {
    number: "03",
    title: "17 Lifecycle Archetypes: 157% Velocity Improvement",
    description: "One nurture track. One set of content. Same emails to everyone. Lead-to-value averaged 47 days. We mapped 17 distinct buyer archetypes — each with custom content types, channel orchestration, and velocity rules — and cut that to 19 days.",
    keyMetric: "157%",
    metricLabel: "Velocity Improvement",
    image: "/case-studies/hero-image-03.png",
    concepts: ["Lifecycle archetypes", "Multi-channel orchestration", "First-party audience sync", "Real-time classification"],
    url: "/case-studies/lifecycle-archetypes"
  },
  {
    number: "04",
    title: "Three Weeks to Fix a 300% Cost Increase",
    description: "April 2021. Apple releases iOS 14.5. Meta's pixel starts lying. SQL costs tripled overnight on a $13M marketing budget. We had three weeks to pivot the entire demand gen engine from pixel-dependent paid social to ABM, first-party data, and channel diversification.",
    keyMetric: "30%",
    metricLabel: "SQL Cost Reduction",
    image: "/case-studies/digital-disconnect.webp",
    concepts: ["Privacy pivot", "Channel diversification", "ABM", "CRM optimization"],
    url: "/case-studies/privacy-pivot"
  },
  {
    number: "05",
    title: "Two-Sided Acquisition for Government Expert Networks",
    description: "Two-sided marketplaces have a chicken-and-egg problem. We scraped SAM.gov, USAspending, and LinkedIn to build simultaneous demand-side and supply-side acquisition engines — matching government contractors with former federal executives at scale.",
    keyMetric: "30%",
    metricLabel: "CAC Reduction",
    image: "/case-studies/government-marketplace.webp",
    concepts: ["Two-sided marketplace", "Public data sourcing", "SEO infrastructure", "Automation"],
    url: "/case-studies/government-marketplace"
  },
  {
    number: "06",
    title: "Clean Room Data Architecture: Privacy-First Measurement",
    description: "This was 2017 — before GDPR, before CCPA, before App Tracking Transparency. We built privacy-first cross-screen attribution using data clean rooms because our customers' first-party data couldn't be combined with media exposure data without creating contractual nightmares.",
    keyMetric: "First",
    metricLabel: "Privacy-First Before Mandates",
    image: "/case-studies/clean-rooms.webp",
    concepts: ["Data clean rooms", "Privacy architecture", "Cross-screen attribution", "Measurement"],
    url: "/case-studies/clean-rooms"
  }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/case-studies/case-studies-hero.webp"
>

  <!-- Hero -->
  <section class="section bg-black overflow-hidden">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-caption text-blue-bright tracking-wide mb-6 font-bold" data-kinetic data-kinetic-direction="left">Case Studies</p>
          <h1 class="text-display-lg text-white font-extrabold mb-8" data-kinetic-up>
            Systems I've built. Problems I've solved.
          </h1>
          <p class="text-body-lg text-gray-300" data-kinetic data-kinetic-direction="right">
            Each case study walks through the situation, the insight, the system architecture, and the measurable outcome. Real infrastructure, real results.
          </p>
        </div>
        <div class="rounded-xl overflow-hidden">
          <img
            src="/case-studies/case-studies-hero.webp"
            alt="Growth infrastructure case studies"
            class="w-full h-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study Cards -->
  <section class="section border-t border-gray-800 overflow-hidden">
    <div class="container-content">
      <p class="section-label" data-kinetic data-kinetic-direction="left">Growth Infrastructure Series</p>
      <h2 class="text-display mb-12" data-kinetic-up>Selected Case Studies</h2>

      <div class="grid md:grid-cols-2 gap-8">
        {caseStudies.map((cs) => (
          <a
            href={cs.url}
            class="block group rounded-2xl border border-gray-800 overflow-hidden hover:border-[#0165fc] transition-colors duration-300"
            data-animate
          >
            <!-- Featured Image -->
            <div class="aspect-[16/9] overflow-hidden bg-[#0a0f1a] relative">
              <img
                src={cs.image}
                alt={cs.title}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-4 left-4">
                <span class="bg-[#0165fc] text-white text-xs font-bold px-3 py-1 rounded">
                  Case Study {cs.number}
                </span>
              </div>
              <div class="absolute bottom-4 right-4">
                <span class="bg-black/70 text-white text-sm font-extrabold px-3 py-1.5 rounded">
                  {cs.keyMetric} <span class="font-normal text-gray-300 text-xs">{cs.metricLabel}</span>
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6 md:p-8">
              <h3 class="text-heading text-white font-bold mb-3 group-hover:text-[#0165fc] transition-colors leading-tight">
                {cs.title}
              </h3>
              <p class="text-body text-gray-400 mb-5 line-clamp-3">
                {cs.description}
              </p>

              <!-- Concept tags -->
              <div class="flex flex-wrap gap-2 mb-4">
                {cs.concepts.map((concept) => (
                  <span class="text-xs text-gray-500 border border-gray-700 rounded-full px-2.5 py-0.5">
                    {concept}
                  </span>
                ))}
              </div>

              <span class="text-[#0165fc] font-bold text-sm group-hover:translate-x-1 transition-transform inline-block">
                Read case study &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section border-t border-gray-800 bg-black overflow-hidden">
    <div class="container-content text-center">
      <h2 class="text-display text-white font-extrabold mb-4" data-scroll-scale data-scale-start="0.9" data-scale-end="1">See something relevant?</h2>
      <p class="text-body-lg text-gray-300 mb-8 max-w-prose mx-auto" data-kinetic-up>
        These case studies represent a fraction of the systems I've built.
        If you're facing a similar challenge, let's talk.
      </p>
      <div class="flex flex-wrap gap-8 justify-center">
        <a href="mailto:nick@strategnik.com" class="text-white font-bold hover:text-[#0165fc] transition-colors text-lg" data-kinetic data-kinetic-direction="left">
          Get in touch &rarr;
        </a>
        <a href="/experience" class="text-[#0165fc] font-bold hover:text-white transition-colors text-lg" data-kinetic data-kinetic-direction="right">
          Full experience &rarr;
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
