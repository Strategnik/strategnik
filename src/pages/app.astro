---
import Analytics from '@vercel/analytics/astro';
import '../styles/ontogent.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1280" />
    <title>Ontogent · by Strategnik · control plane</title>
    <meta name="description" content="The control plane for AI-native brand systems. Built by Strategnik." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <Analytics />
  </head>
  <body style="margin:0; padding:0; background:#07080a;">
    <div id="ontogent-root">
      <div id="ont-app"></div>
    </div>
    <script>
      import { createElement } from 'react';
      import { createRoot } from 'react-dom/client';
      import OntogentApp from '../components/ontogent/OntogentApp';

      const root = createRoot(document.getElementById('ont-app')!);
      root.render(createElement(OntogentApp));
    </script>
  </body>
</html>
